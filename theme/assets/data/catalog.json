---
layout: null
permalink: /assets/data/catalog.json
# Generated at build time from data/. Do not edit this file directly — edit the
# YAML under data/definitions/ and data/working-groups/ and Jekyll regenerates it.
# layout:null keeps the site-wide default `page` layout from wrapping this JSON
# in HTML.
#
# The two top-level keys mirror the two halves of data/:
#   definitions — static vocabularies. The SLSA mirrors change only when SLSA does.
#   catalog  — the projects and working groups, assembled from
#              data/working-groups/*.yml. Each project carries a `working_group`
#              derived from the file it lives in; null means the TAC list does not
#              place it yet (see working-groups/uncategorized.yml).
#
# Threat mitigations are NOT stored on the threat records. A record claims the
# threats it mitigates via its own `threats` list; reverse-lookup by threat id
# to build a mitigation list.
---
{
  "definitions": {
    "personas": {{ site.data.definitions.personas | jsonify }},
    "problems": {{ site.data.definitions.problems | jsonify }},
    "categories": {{ site.data.definitions.categories | jsonify }},
    "sdlc_stages": {{ site.data.definitions.sdlc_stages | jsonify }},
    "supply_chain_actors": {{ site.data.definitions.supply_chain_actors | jsonify }},
    "slsa_threats": {{ site.data.definitions.slsa_threats | jsonify }},
    "slsa_threat_categories": {{ site.data.definitions.slsa_threat_categories | jsonify }},
    "artifacts": {{ site.data.definitions.artifacts | jsonify }}
  },
  "catalog": {
    "projects": {{ site.data.catalog.projects | jsonify }},
    "working_groups": {{ site.data.catalog.working_groups | jsonify }}
  }
}
