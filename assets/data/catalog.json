---
layout: null
# Generated at build time from the three master lists in _data/.
# Do not edit this file directly — edit personas.yml / problems.yml /
# projects.yml and Jekyll will regenerate it. layout:null keeps the site-wide
# default `page` layout from wrapping this JSON in HTML.
---
{
  "personas": {{ site.data.personas | jsonify }},
  "problems": {{ site.data.problems | jsonify }},
  "projects": {{ site.data.projects | jsonify }}
}
